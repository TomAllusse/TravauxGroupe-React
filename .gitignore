# Dépendances (très lourd, généré via npm install)
node_modules/

# Configuration de l'IDE (WebStorm / IntelliJ)
.idea/

# Fichiers de build (générés lors du déploiement)
dist/
build/

# Variables d'environnement (contient souvent des clés API secrètes)
.env
.env.local

# Logs d'erreurs
npm-debug.log*
yarn-debug.log*
yarn-error.log*